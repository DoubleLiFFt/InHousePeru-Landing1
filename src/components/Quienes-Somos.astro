---
import { Image } from "astro:assets";
import ImageText from '../assets/Advice.jpg'

const texto = 'Fundada en 2022, inHouse Perú brinda asesoria estratégica y capacitación especializada. Transformamos' +
    ' la gestión de entidades públicas y privadas con soluciones efectivas basadas en amplia experiencia sectorial.'
---
<section id="quienes-somos" class="relative w-full min-h-screen grid grid-cols-1 md:grid-cols-2 items-stretch overflow-hidden font-sans border-slate-100 scroll-mt-20">

    <div class="relative z-20 flex flex-col justify-center gap-6 text-left p-12 sm:p-16 md:p-16 lg:p-24 xl:p-32 bg-white/5 backdrop-blur-sm md:backdrop-blur-0 md:bg-white order-2 md:order-1">
        <div class="space-y-2">
            <span class="text-[#00BCD4] font-bold tracking-[0.3em] uppercase text-xs md:text-sm">Trayectoria y Confianza</span>

            <h1 class="text-4xl sm:text-5xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-white md:text-[#001F5B]">
                ¿Quiénes <span class="text-[#00BCD4]">somos?</span>
            </h1>
        </div>

        <p class="text-lg sm:text-xl md:text-xl lg:text-2xl text-slate-100 md:text-slate-700 leading-relaxed font-medium">
            {texto}
        </p>

        <div class="flex gap-4 pt-4">
            <div class="h-1 w-20 bg-[#00BCD4] rounded-full"></div>
            <div class="h-1 w-8 bg-white/40 md:bg-[#001F5B]/20 rounded-full"></div>
        </div>
    </div>

    <div class="absolute md:relative inset-0 md:inset-auto z-10 md:z-auto group overflow-hidden order-1 md:order-2">

        <div class="absolute inset-0 bg-black/60 md:bg-black/50 z-10 transition-colors duration-500 group-hover:bg-black/50 md:group-hover:bg-black/40"></div>

        <Image
                src={ImageText}
                alt="Consultoría estratégica Inhouse Perú"
                quality="high"
                class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105"
        />

        <div class="absolute inset-6 border border-white/20 z-20 pointer-events-none rounded-lg hidden md:block"></div>
    </div>
</section>